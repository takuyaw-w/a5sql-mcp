{
  "name": "@takuyaw-w/a5sql-mcp-workspace",
  "version": "0.10.2",
  "private": true,
  "keywords": [
    "a5er",
    "a5sql",
    "a5sql-mk2",
    "database",
    "erd",
    "mcp",
    "model-context-protocol",
    "schema",
    "sql"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "local": "node packages/cli/dist/index.js",
    "agent:preflight": "node scripts/agent-preflight.mjs",
    "pack:check": "pnpm --filter @takuyaw-w/a5sql-mcp-parser pack --dry-run && pnpm --filter @takuyaw-w/a5sql-mcp-core pack --dry-run && pnpm --filter @takuyaw-w/a5sql-mcp pack --dry-run",
    "published:check": "pnpm build && pnpm --filter @takuyaw-w/a5sql-mcp published:check",
    "release:check": "pnpm format:check && pnpm lint && pnpm build && pnpm test && pnpm typecheck && pnpm pack:check",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.7.0"
}
